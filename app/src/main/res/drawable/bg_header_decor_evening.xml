<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <item
        android:right="-40dp"
        android:top="-30dp">
        <shape android:shape="oval">
            <solid android:color="#18FFFFFF" />
            <size
                android:width="180dp"
                android:height="180dp" />
        </shape>
    </item>
    <item
        android:left="60dp"
        android:top="20dp">
        <shape android:shape="oval">
            <solid android:color="#12FFFFFF" />
            <size
                android:width="100dp"
                android:height="100dp" />
        </shape>
    </item>
    <item
        android:left="-20dp"
        android:bottom="-20dp">
        <shape android:shape="oval">
            <solid android:color="#10FFFFFF" />
            <size
                android:width="120dp"
                android:height="120dp" />
        </shape>
    </item>
    <!-- Stars for evening -->
    <item
        android:left="80dp"
        android:top="30dp">
        <shape android:shape="oval">
            <solid android:color="#40FFFFFF" />
            <size android:width="3dp" android:height="3dp" />
        </shape>
    </item>
    <item
        android:left="150dp"
        android:top="55dp">
        <shape android:shape="oval">
            <solid android:color="#30FFFFFF" />
            <size android:width="2dp" android:height="2dp" />
        </shape>
    </item>
    <item
        android:left="200dp"
        android:top="25dp">
        <shape android:shape="oval">
            <solid android:color="#35FFFFFF" />
            <size android:width="2dp" android:height="2dp" />
        </shape>
    </item>
    <item
        android:left="50dp"
        android:top="70dp">
        <shape android:shape="oval">
            <solid android:color="#25FFFFFF" />
            <size android:width="2dp" android:height="2dp" />
        </shape>
    </item>
</layer-list>
