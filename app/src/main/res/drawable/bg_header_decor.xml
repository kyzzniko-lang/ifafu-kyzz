<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <item
        android:right="-60dp"
        android:top="-40dp">
        <shape android:shape="oval">
            <solid android:color="#18FFFFFF" />
            <size
                android:width="200dp"
                android:height="200dp" />
        </shape>
    </item>
    <item
        android:left="80dp"
        android:top="30dp">
        <shape android:shape="oval">
            <solid android:color="#12FFFFFF" />
            <size
                android:width="120dp"
                android:height="120dp" />
        </shape>
    </item>
    <item
        android:left="-30dp"
        android:bottom="-30dp">
        <shape android:shape="oval">
            <solid android:color="#10FFFFFF" />
            <size
                android:width="140dp"
                android:height="140dp" />
        </shape>
    </item>
    <item
        android:right="40dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#0AFFFFFF" />
            <size
                android:width="80dp"
                android:height="80dp" />
        </shape>
    </item>
</layer-list>
