<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.iFAFUKYZZ" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/claude_terracotta</item>
        <item name="colorPrimaryVariant">@color/claude_terracotta_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/claude_terracotta_light</item>
        <item name="colorSecondaryVariant">@color/claude_terracotta_300</item>
        <item name="colorOnSecondary">@color/claude_text_primary</item>
        <item name="android:statusBarColor">@color/claude_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/claude_bg</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/claude_bg</item>
        <item name="android:colorBackground">@color/claude_bg</item>
        <item name="android:textColorPrimary">@color/claude_text_primary</item>
        <item name="android:textColorSecondary">@color/claude_text_secondary</item>
        <item name="android:textColorHint">@color/claude_text_hint</item>
    </style>

    <style name="ClaudeDisplay">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/claude_text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <style name="ClaudeDisplay.Light">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="ClaudeHeadline">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/claude_text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="ClaudeTitle">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/claude_text_primary</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="ClaudeTitle.Light">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="ClaudeSubtitle">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/claude_text_secondary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="ClaudeSubtitle.Light">
        <item name="android:textColor">#B3FFFFFF</item>
    </style>

    <style name="ClaudeBody">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/claude_text_primary</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="ClaudeBody.Secondary">
        <item name="android:textColor">@color/claude_text_secondary</item>
    </style>

    <style name="ClaudeCaption">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/claude_text_tertiary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="ClaudeOverline">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/claude_text_tertiary</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="ClaudeButton" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/claude_terracotta</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">4dp</item>
        <item name="android:insetBottom">4dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="ClaudeButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/claude_terracotta</item>
        <item name="strokeColor">@color/claude_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="ClaudeButton.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/claude_terracotta</item>
        <item name="cornerRadius">100dp</item>
    </style>

    <style name="ClaudeCard">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/claude_bg_elevated</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/claude_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="ClaudeCard.Elevated">
        <item name="cardElevation">4dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="ClaudeInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/claude_terracotta</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="hintTextColor">@color/claude_terracotta</item>
        <item name="android:textColorHint">@color/claude_text_hint</item>
    </style>

    <style name="ClaudeChip" parent="Widget.Material3.Chip.Suggestion">
        <item name="android:fontFamily">@font/claude_serif</item>
        <item name="chipCornerRadius">100dp</item>
        <item name="chipStrokeColor">@color/claude_border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipBackgroundColor">@color/claude_bg_elevated</item>
        <item name="android:textColor">@color/claude_text_secondary</item>
    </style>

    <style name="ClaudeChip.Selected">
        <item name="chipBackgroundColor">@color/claude_terracotta</item>
        <item name="android:textColor">@color/white</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>
</resources>
