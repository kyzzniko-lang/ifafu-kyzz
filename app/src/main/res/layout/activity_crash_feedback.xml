<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/claude_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/claude_bg"
        android:elevation="0dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/claude_text_primary"
        app:title="崩溃反馈"
        app:titleTextAppearance="@style/ClaudeTitle"
        app:titleTextColor="@color/claude_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                style="@style/ClaudeHeadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="应用遇到了问题"
                android:textColor="@color/claude_text_primary" />

            <TextView
                style="@style/ClaudeBody.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="抱歉，应用上次异常退出了。你可以把这次的崩溃信息反馈给开发者，帮助我们修复问题。" />

            <com.google.android.material.card.MaterialCardView
                style="@style/ClaudeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:strokeColor="@color/claude_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/claude_serif"
                        android:textColor="@color/claude_text_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvTrace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/claude_text_secondary"
                        android:textIsSelectable="true"
                        android:textSize="11sp" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/ClaudeSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="补充说明（可选）" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/ClaudeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="例如：打开成绩页时闪退">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:maxLines="4"
                    android:minLines="2"
                    android:textColor="@color/claude_text_primary" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/claude_serif"
                android:textColor="@color/claude_text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btnCopy"
            style="@style/ClaudeButton.Outlined"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="复制日志" />

        <Button
            android:id="@+id/btnSubmit"
            style="@style/ClaudeButton.Solid"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="提交反馈" />

    </LinearLayout>

</LinearLayout>
