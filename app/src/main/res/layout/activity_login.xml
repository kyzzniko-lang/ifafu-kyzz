<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/claude_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="36dp"
            android:paddingTop="96dp"
            android:paddingBottom="48dp">

            <!-- Wordmark / brand line -->
            <TextView
                android:id="@+id/ivLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:fontFamily="@font/claude_serif"
                android:letterSpacing="0.32"
                android:text="iFAFU"
                android:textAllCaps="true"
                android:textColor="@color/claude_text_tertiary"
                android:textSize="11sp" />

            <!-- App title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:alpha="0"
                android:fontFamily="@font/claude_serif"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="1.1"
                android:text="@string/app_name"
                android:textColor="@color/claude_text_primary"
                android:textSize="40sp" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:alpha="0"
                android:fontFamily="@font/claude_serif"
                android:letterSpacing="0.01"
                android:text="@string/login_subtitle"
                android:textColor="@color/claude_text_secondary"
                android:textSize="15sp" />

            <!-- Hairline divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginTop="56dp"
                android:background="@color/claude_divider" />

            <!-- Account selector (multi-account) -->
            <LinearLayout
                android:id="@+id/accountSelectorLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:alpha="0"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/claude_serif"
                    android:letterSpacing="0.08"
                    android:text="选择账号"
                    android:textAllCaps="true"
                    android:textColor="@color/claude_text_tertiary"
                    android:textSize="11sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAccounts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never" />

            </LinearLayout>

            <!-- Account label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/claude_serif"
                android:letterSpacing="0.08"
                android:text="学号"
                android:textAllCaps="true"
                android:textColor="@color/claude_text_tertiary"
                android:textSize="11sp" />

            <!-- Account input (thin outlined, document feel) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAccount"
                style="@style/ClaudeInputUnderline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0"
                android:hint=" "
                app:placeholderText="请输入学号"
                app:placeholderTextColor="@color/claude_text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/claude_serif"
                    android:inputType="number"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/claude_text_primary"
                    android:textColorHint="@color/claude_text_hint"
                    android:textSize="16sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/claude_serif"
                android:letterSpacing="0.08"
                android:text="密码"
                android:textAllCaps="true"
                android:textColor="@color/claude_text_tertiary"
                android:textSize="11sp" />

            <!-- Password input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/ClaudeInputUnderline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0"
                android:hint=" "
                app:endIconMode="password_toggle"
                app:endIconTint="@color/claude_text_tertiary"
                app:placeholderText="请输入教务系统密码"
                app:placeholderTextColor="@color/claude_text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/claude_serif"
                    android:inputType="textPassword"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/claude_text_primary"
                    android:textColorHint="@color/claude_text_hint"
                    android:textSize="16sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Login button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="40dp"
                android:alpha="0">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    style="@style/ClaudeButton.Solid"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/btn_login" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/white"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- Error message -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:alpha="0"
                android:fontFamily="@font/claude_serif"
                android:gravity="center"
                android:textColor="@color/claude_error"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Footer hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:alpha="0"
                android:fontFamily="@font/claude_serif"
                android:gravity="center"
                android:letterSpacing="0.04"
                android:text="登录即表示同意相关服务条款"
                android:textColor="@color/claude_text_tertiary"
                android:textSize="11sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
