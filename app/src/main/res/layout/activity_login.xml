<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fitsSystemWindows="true"
    android:gravity="center"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="32dp">

        <!-- Logo area -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:alpha="0"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_banner_kyzz" />

        <!-- App title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:alpha="0"
            android:fontFamily="@font/claude_serif"
            android:letterSpacing="-0.02"
            android:text="@string/app_name"
            android:textColor="#EDEBE8"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0"
            android:fontFamily="@font/claude_serif"
            android:text="@string/login_subtitle"
            android:textColor="@color/claude_text_secondary"
            android:textSize="14sp" />

        <!-- Account selector (multi-account) -->
        <LinearLayout
            android:id="@+id/accountSelectorLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:alpha="0"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/claude_serif"
                android:text="选择账号"
                android:textColor="@color/claude_text_hint"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAccounts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never" />

        </LinearLayout>

        <!-- Account input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAccount"
            style="@style/ClaudeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:alpha="0"
            android:background="@drawable/bg_login_input"
            android:hint="@string/hint_account"
            app:boxStrokeColor="@color/claude_terracotta"
            app:hintTextColor="@color/claude_text_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/claude_serif"
                android:hint="学号"
                android:inputType="number"
                android:padding="16dp"
                android:textColor="@color/claude_text_primary"
                android:textColorHint="@color/claude_text_hint"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/ClaudeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:alpha="0"
            android:background="@drawable/bg_login_input"
            android:hint="@string/hint_password"
            app:boxStrokeColor="@color/claude_terracotta"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/claude_text_hint"
            app:hintTextColor="@color/claude_text_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/claude_serif"
                android:hint="密码"
                android:inputType="textPassword"
                android:padding="16dp"
                android:textColor="@color/claude_text_primary"
                android:textColorHint="@color/claude_text_hint"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Login button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:alpha="0">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                style="@style/ClaudeButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_button_primary"
                android:fontFamily="@font/claude_serif"
                android:letterSpacing="0.05"
                android:text="@string/btn_login"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@null"
                app:cornerRadius="100dp"
                app:elevation="0dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/white"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Error message -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:alpha="0"
            android:fontFamily="@font/claude_serif"
            android:gravity="center"
            android:textColor="@color/claude_error"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Footer hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:alpha="0"
            android:fontFamily="@font/claude_serif"
            android:gravity="center"
            android:text="登录即表示同意相关服务条款"
            android:textColor="@color/claude_text_hint"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
