<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_modern"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:fitsSystemWindows="true">

    <View
        android:id="@+id/ambientGlow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-120dp"
        android:layout_marginEnd="-100dp"
        android:alpha="0.24"
        android:background="@drawable/bg_ambient_glow" />

    <View
        android:id="@+id/ambientGlow2"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-110dp"
        android:layout_marginBottom="-80dp"
        android:alpha="0.12"
        android:background="@drawable/bg_ambient_glow_secondary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="30dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/brandHeader"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/ivLogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0"
                    android:fontFamily="@font/claude_display"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.02"
                    android:text="iFAFU"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="22sp"
                    android:textStyle="italic" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/claude_serif"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.02"
                        android:text="福农校园助手"
                        android:textColor="@color/claude_text_secondary"
                        android:textSize="12sp" />


                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:alpha="0"
                android:fontFamily="@font/claude_serif"
                android:includeFontPadding="false"
                android:text="欢迎回来"
                android:textColor="@color/claude_text_primary"
                android:textSize="36sp" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:alpha="0"
                android:fontFamily="@font/claude_serif"
                android:lineSpacingExtra="3dp"
                android:text="登录后查看你的课表、成绩与考试安排"
                android:textColor="@color/claude_text_secondary"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/accountSelectorLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="选择已保存账号"
                    android:textColor="@color/claude_text_secondary"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAccounts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/loginCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/login_card_bg"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/claude_serif"
                        android:text="教务系统账号"
                        android:textColor="@color/claude_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/claude_serif"
                        android:text="账号信息仅保存在本机"
                        android:textColor="@color/claude_text_tertiary"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilAccount"
                        style="@style/LoginInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:alpha="0"
                        android:hint="学号"
                        app:startIconDrawable="@drawable/ic_login_user"
                        app:startIconTint="@color/login_input_icon">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAccount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="username"
                            android:fontFamily="sans-serif"
                            android:imeOptions="actionNext"
                            android:inputType="number"
                            android:maxLines="1"
                            android:selectAllOnFocus="false"
                            android:textColor="@color/claude_text_primary"
                            android:textColorHint="@color/claude_text_hint"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        style="@style/LoginInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:alpha="0"
                        android:hint="教务系统密码"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/login_input_icon"
                        app:startIconDrawable="@drawable/ic_login_lock"
                        app:startIconTint="@color/login_input_icon">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="password"
                            android:fontFamily="sans-serif"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="@color/claude_text_primary"
                            android:textColorHint="@color/claude_text_hint"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="22dp"
                        android:alpha="0">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_button_shimmer" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLogin"
                            style="@style/LoginPrimaryButton"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="@string/btn_login" />

                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/login_button_text"
                            android:visibility="gone" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:alpha="0"
                        android:fontFamily="@font/claude_serif"
                        android:gravity="center"
                        android:textColor="@color/claude_error"
                        android:textSize="13sp"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_login_secure_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                        android:fontFamily="@font/claude_serif"
                    android:text="安全连接至福建农林大学教务系统"
                    android:textColor="@color/claude_text_tertiary"
                    android:textSize="11sp" />

            </LinearLayout>

            <Space
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="登录即表示同意相关服务条款"
                android:textColor="@color/claude_text_tertiary"
                android:textSize="11sp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>
