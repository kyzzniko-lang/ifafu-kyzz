<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/claude_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/claude_bg"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="虚拟定位"
        app:titleTextColor="@color/claude_text_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Warning card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/ClaudeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:strokeColor="@color/claude_warning"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="使用说明"
                        android:textColor="@color/claude_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="1. 手机设置 → 关于手机 → 连续点击「版本号」7次开启开发者模式\n2. 设置 → 开发者选项 → 选择模拟位置信息应用 → 选择本应用\n3. 点击下方校区按钮快速定位，或在地图上选点/手动输入\n4. 点击「开始模拟定位」"
                        android:textColor="@color/claude_text_secondary"
                        android:textSize="13sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Map card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMap"
                style="@style/ClaudeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <WebView
                    android:id="@+id/webView"
                    android:layout_width="match_parent"
                    android:layout_height="250dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Campus quick-select card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCampusSelect"
                style="@style/ClaudeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="校区位置"
                        android:textColor="@color/claude_text_hint"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCampusJinshan"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="金山"
                        android:textColor="@color/claude_terracotta"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/claude_terracotta"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCampusQishan"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="旗山"
                        android:textColor="@color/claude_terracotta"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/claude_terracotta"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCampusAnxi"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="安溪"
                        android:textColor="@color/claude_terracotta"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/claude_terracotta"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCampusNanping"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="南平"
                        android:textColor="@color/claude_terracotta"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/claude_terracotta"
                        app:strokeWidth="1dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Trajectory mode card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTrajectory"
                style="@style/ClaudeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Mode toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif"
                            android:text="轨迹模式"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchTrajectoryMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Trajectory controls (shown when trajectory mode is on) -->
                    <LinearLayout
                        android:id="@+id/layoutTrajectoryControls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/inputSpeed"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="速度"
                            app:boxBackgroundColor="@color/claude_bg_subtle"
                            app:boxStrokeColor="@color/claude_terracotta"
                            app:suffixText="m/s"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSpeed"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:text="1.2"
                                android:textSize="15sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Loop mode toggle -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="校园跑模式（首尾相连循环）"
                                android:textColor="@color/claude_text_primary"
                                android:textSize="14sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchLoopMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                        </LinearLayout>

                        <!-- Lap count (shown when loop mode is on) -->
                        <LinearLayout
                            android:id="@+id/layoutLapCount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="跑步圈数"
                                android:textColor="@color/claude_text_secondary"
                                android:textSize="13sp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/inputLapCount"
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:hint="圈数"
                                app:boxBackgroundColor="@color/claude_bg_subtle"
                                app:boxStrokeColor="@color/claude_terracotta"
                                app:helperText="0=无限"
                                app:helperTextTextColor="@color/claude_text_hint"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etLapCount"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:maxLength="3"
                                    android:text="0"
                                    android:textAlignment="center"
                                    android:textSize="15sp" />

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvWaypointInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="点击地图添加路径点（至少2个）"
                            android:textColor="@color/claude_text_hint"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvTrajectoryStats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text=""
                            android:textColor="@color/claude_terracotta"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUndoWaypoint"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:enabled="false"
                                android:text="撤销"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp"
                                app:strokeColor="@color/claude_terracotta" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnClearWaypoints"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:enabled="false"
                                android:text="清除"
                                android:textAllCaps="false"
                                app:cornerRadius="10dp"
                                app:strokeColor="@color/claude_terracotta" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Coordinate inputs -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCoords"
                style="@style/ClaudeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="纬度 (如 26.085206)"
                        app:boxBackgroundColor="@color/claude_bg_subtle"
                        app:boxStrokeColor="@color/claude_terracotta"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLatitude"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal|numberSigned"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="经度 (如 119.239669)"
                        app:boxBackgroundColor="@color/claude_bg_subtle"
                        app:boxStrokeColor="@color/claude_terracotta"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLongitude"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal|numberSigned"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvPickedCoords"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="点击地图或校区按钮自动填入"
                        android:textColor="@color/claude_text_hint"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Start/Stop button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartStop"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:text="开始模拟定位"
                android:textSize="16sp"
                app:backgroundTint="@color/claude_terracotta"
                app:cornerRadius="14dp" />

            <!-- Status text -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="未启动"
                android:textColor="@color/claude_text_hint"
                android:textSize="13sp" />

            <!-- Battery optimization warning -->
            <TextView
                android:id="@+id/tvBatteryWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="⚠ 电池优化未关闭，虚拟定位可能被系统中断"
                android:textColor="#E53935"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Background keep-alive card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/ClaudeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="后台保活设置"
                        android:textColor="@color/claude_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="为保证虚拟定位在后台持续运行（类似音乐播放器），请完成以下设置："
                        android:textColor="@color/claude_text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBatteryOpt"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="1. 关闭电池优化（防系统杀进程）"
                        android:textAllCaps="false"
                        android:textColor="@color/claude_terracotta"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_lock_idle_lock"
                        app:iconTint="@color/claude_terracotta"
                        app:strokeColor="@color/claude_terracotta" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAutoStart"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="2. 允许自启动（开机自动恢复定位）"
                        android:textAllCaps="false"
                        android:textColor="@color/claude_terracotta"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_lock_power_off"
                        app:iconTint="@color/claude_terracotta"
                        app:strokeColor="@color/claude_terracotta" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNotificationSettings"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="3. 允许通知（前台服务必需）"
                        android:textAllCaps="false"
                        android:textColor="@color/claude_terracotta"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_popup_reminder"
                        app:iconTint="@color/claude_terracotta"
                        app:strokeColor="@color/claude_terracotta" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="提示：部分手机（小米/OPPO/vivo/华为）还需要在各自的安全中心中允许本应用自启动和后台运行。"
                        android:textColor="@color/claude_text_hint"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
