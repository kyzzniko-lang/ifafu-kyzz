<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/claude_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/claude_bg"
        android:elevation="0dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/claude_text_primary"
        app:titleTextAppearance="@style/ClaudeTitle"
        app:titleTextColor="@color/claude_text_primary" />

    <!-- 模式选择区域 -->
    <LinearLayout
        android:id="@+id/layoutModeSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="选择评价模式"
            android:textColor="@color/claude_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbFullAuto"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:checked="true"
                android:paddingStart="8dp"
                android:text="全自动评价（随机优秀/良好/中等）"
                android:textColor="@color/claude_text_primary"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbSemiAuto"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="8dp"
                android:text="半自动评价（自选评分区间）"
                android:textColor="@color/claude_text_primary"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbManual"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="8dp"
                android:text="手动评价（逐项选择）"
                android:textColor="@color/claude_text_primary"
                android:textSize="15sp" />
        </RadioGroup>

        <!-- 半自动：评分区间选择 -->
        <LinearLayout
            android:id="@+id/layoutSemiAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="评分区间："
                android:textColor="@color/claude_text_secondary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerMin"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="@color/claude_text_primary"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/spinnerMax"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_primary" />
        </LinearLayout>
    </LinearLayout>

    <!-- 状态/进度 -->
    <TextView
        android:id="@+id/tvStatus"
        style="@style/ClaudeSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:paddingHorizontal="24dp"
        android:text="点击下方按钮开始评教"
        android:textAlignment="center"
        android:textColor="@color/claude_text_secondary" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:indeterminateTint="@color/claude_terracotta"
        android:visibility="gone" />

    <!-- 开始按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        style="@style/ClaudeButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_primary"
        android:text="开始评教"
        app:backgroundTint="@null" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitFinal"
        style="@style/ClaudeButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_primary"
        android:text="提交总表（所有课程评价完成后点击）"
        android:textSize="13sp"
        android:visibility="visible"
        app:backgroundTint="@null" />

    <!-- 手动模式：评价项列表 -->
    <LinearLayout
        android:id="@+id/layoutManual"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:visibility="gone">

        <Spinner
            android:id="@+id/spnCourses"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTeacherName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:textColor="@color/claude_text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhitelist"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="特别关照"
                android:textSize="12sp"
                android:visibility="gone"
                app:iconSize="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBlacklist"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="拉黑此教师"
                android:textSize="12sp"
                android:visibility="gone"
                app:iconSize="16dp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItems"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutPerCourseComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:hint="对这位教师的评价与建议（选填）"
            app:boxBackgroundColor="@color/claude_bg_elevated"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:boxStrokeColor="@color/claude_terracotta"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPerCourseComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLength="500"
                android:minLines="2"
                android:maxLines="3"
                android:gravity="top|start"
                android:textColor="@color/claude_text_primary"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/ClaudeButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_button_primary"
            android:text="保存并下一门"
            app:backgroundTint="@null" />
    </LinearLayout>

</LinearLayout>
