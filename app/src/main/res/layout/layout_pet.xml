<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Bubble -->
    <LinearLayout
        android:id="@+id/petBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="70dp"
        android:background="@drawable/bg_pet_bubble"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvBubbleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/claude_serif"
            android:textColor="#333333"
            android:textSize="12sp"
            android:maxWidth="160dp" />

    </LinearLayout>

    <!-- Status label -->
    <TextView
        android:id="@+id/tvPetStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="65dp"
        android:background="@drawable/bg_pet_status"
        android:fontFamily="@font/claude_serif"
        android:textColor="@color/claude_text_secondary"
        android:textSize="10sp"
        android:visibility="gone" />

    <!-- Pet info bar -->
    <LinearLayout
        android:id="@+id/petInfoBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="88dp"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="2dp">

        <!-- Level + Title -->
        <TextView
            android:id="@+id/tvPetLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/claude_serif"
            android:textSize="10sp"
            android:textColor="@color/claude_text_secondary"
            android:text="Lv.1 小奶猫" />

        <!-- Mini stats: mood + hunger bars -->
        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_pet_status" />
            <ProgressBar
                android:id="@+id/miniMoodBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="80"
                android:progressTint="@color/claude_terracotta"
                android:progressBackgroundTint="@color/claude_border" />
            <View
                android:layout_width="4dp"
                android:layout_height="0dp" />
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_pet_status" />
            <ProgressBar
                android:id="@+id/miniHungerBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="60"
                android:progressTint="@color/claude_success"
                android:progressBackgroundTint="@color/claude_border" />
        </LinearLayout>

        <!-- Check-in indicator -->
        <TextView
            android:id="@+id/tvCheckIn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/claude_serif"
            android:textSize="9sp"
            android:textColor="@color/claude_terracotta"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Cat image -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/ivPet"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="center"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:src="@drawable/pet_cat_idle" />

</FrameLayout>
