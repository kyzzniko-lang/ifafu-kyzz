<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Time column -->
    <LinearLayout
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal|end"
        android:orientation="vertical"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tvTimeStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/claude_serif"
            android:textColor="@color/claude_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTimeEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/claude_serif"
            android:textColor="@color/claude_text_hint"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Timeline dot + line -->
    <LinearLayout
        android:layout_width="20dp"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <View
            android:id="@+id/timelineDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/timeline_dot" />

        <View
            android:id="@+id/timelineLine"
            android:layout_width="1.5dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/claude_border" />

    </LinearLayout>

    <!-- Course info card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCourse"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/claude_border"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvCourseName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/claude_serif"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCourseWeather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/claude_serif"
                    android:textColor="@color/claude_terracotta"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_menu_mapmode"
                    android:alpha="0.5" />

                <TextView
                    android:id="@+id/tvCourseLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/claude_serif"
                    android:textColor="@color/claude_text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:alpha="0.5" />

                <TextView
                    android:id="@+id/tvCourseTeacher"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/claude_serif"
                    android:textColor="@color/claude_text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvCourseStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/claude_serif"
                android:textSize="11sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
