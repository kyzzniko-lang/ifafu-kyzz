<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/claude_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/claude_bg"
        android:elevation="0dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/claude_text_primary"
        app:titleTextAppearance="@style/ClaudeTitle"
        app:titleTextColor="@color/claude_text_primary" />

    <LinearLayout
        android:id="@+id/termSelector"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/claude_bg_elevated"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinnerYear"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleTerm"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerm1"
                style="@style/ClaudeButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="第一学期"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerm2"
                style="@style/ClaudeButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="第二学期"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerm3"
                style="@style/ClaudeButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="第三学期"
                android:textSize="12sp"
                android:visibility="gone" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/weekSelector"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/claude_bg_elevated"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnPrevWeek"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/claude_terracotta" />

        <TextView
            android:id="@+id/tvWeekTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:textColor="@color/claude_text_primary"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/btnNextWeek"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@android:drawable/ic_media_next"
            app:tint="@color/claude_terracotta" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/claude_border" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/headerRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/claude_bg_elevated"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="36dp"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text="节"
                    android:textColor="@color/claude_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text="一"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text="二"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text="三"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text="四"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text="五"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text="六"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text="日"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/dateRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/claude_bg_elevated"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="24dp"
                    android:background="@color/claude_bg_subtle"
                    android:gravity="center"
                    android:text=""
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/tvDateMon"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/claude_text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDateTue"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/claude_text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDateWed"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/claude_text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDateThu"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/claude_text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDateFri"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/claude_text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDateSat"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/claude_text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvDateSun"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/claude_text_hint"
                    android:textSize="10sp" />

            </LinearLayout>

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/claude_bg">

                <ScrollView
                    android:id="@+id/scrollView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/gridContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />

                </ScrollView>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        </LinearLayout>

        <include
            android:id="@+id/petLoading"
            layout="@layout/layout_pet_loading" />

        <include
            android:id="@+id/shimmerLoading"
            layout="@layout/shimmer_syllabus_grid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/errorLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/claude_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvError"
                style="@style/ClaudeBody.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                style="@style/ClaudeButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/retry" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
