<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/claude_bg">

    <View
        android:id="@+id/ambientGlowTop"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:alpha="0.14"
        android:background="@drawable/bg_ambient_glow" />

    <View
        android:id="@+id/ambientGlowBottom"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="200dp"
        android:alpha="0.08"
        android:background="@drawable/bg_ambient_glow_secondary" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="none">

<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="32dp"
                android:paddingBottom="100dp">

                <!-- Hidden legacy header anchors (kept for code compatibility) -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp">

                    <View
                        android:id="@+id/headerBackground"
                        android:layout_width="0dp"
                        android:layout_height="0dp" />

                    <View
                        android:id="@+id/headerBottomArc"
                        android:layout_width="0dp"
                        android:layout_height="0dp" />
                </FrameLayout>

                <!-- Top row: wordmark + settings -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/claude_display"
                        android:letterSpacing="0.28"
                        android:text="iFAFU"
                        android:textAllCaps="true"
                        android:textColor="@color/claude_text_secondary"
                        android:textSize="12sp" />

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="设置"
                        android:padding="8dp"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/claude_text_secondary" />

                </LinearLayout>

<!-- Greeting (typewriter) -->
                <!-- Greeting (typewriter) -->
                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:fontFamily="@font/claude_serif"
                    android:letterSpacing="-0.02"
                    android:lineSpacingMultiplier="1.08"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="36sp"
                    android:textStyle="normal" />

                <!-- Date line: italic Playfair for the numerals/latin, sets a refined classical tone -->
                <TextView
                    android:id="@+id/tvDateInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/claude_serif"
                    android:letterSpacing="0.02"
                    android:textColor="@color/claude_text_secondary"
                    android:textSize="13sp" />

                <!-- Quick info chips (text-only, document style) -->
                <HorizontalScrollView
                    android:id="@+id/chipsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:clipToPadding="false"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipWeek"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_info_chip"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:letterSpacing="0.02"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/claude_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipCoursesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_info_chip"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:letterSpacing="0.02"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/claude_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipExamCountdown"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_info_chip"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:letterSpacing="0.02"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/claude_text_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Hairline divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginTop="36dp"
                    android:background="@color/claude_divider" />

                <!-- Update notification (kept for Kotlin compat, hidden by default) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardUpdate"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/claude_bg_subtle"
                    app:strokeColor="@color/claude_divider"
                    app:strokeWidth="1px">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/claude_serif"
                                android:letterSpacing="0.1"
                                android:text="发现新版本"
                                android:textAllCaps="true"
                                android:textColor="@color/claude_terracotta"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvUpdateSize"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/claude_serif"
                                android:textColor="@color/claude_text_tertiary"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvUpdateVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/claude_serif"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvUpdateBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/claude_serif"
                            android:lineSpacingMultiplier="1.5"
                            android:maxLines="2"
                            android:textColor="@color/claude_text_secondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Weather (kept hidden by default, no card chrome) -->
                <LinearLayout
                    android:id="@+id/cardWeather"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/claude_serif"
                        android:letterSpacing="0.1"
                        android:text="天气"
                        android:textAllCaps="true"
                        android:textColor="@color/claude_terracotta"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvWeatherSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/claude_serif"
                        android:textColor="@color/claude_text_primary"
                        android:textSize="15sp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/weatherPeriodContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />

                    </HorizontalScrollView>

                </LinearLayout>

                <!-- Course progress (subtle hairline bar) -->
                <LinearLayout
                    android:id="@+id/courseProgressContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ProgressBar
                            android:id="@+id/courseProgressBar"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="2dp"
                            android:layout_marginEnd="12dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="0"
                            android:progressBackgroundTint="@color/claude_divider"
                            android:progressTint="@color/claude_text_primary" />

                        <TextView
                            android:id="@+id/courseProgressText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/claude_serif"
                            android:letterSpacing="0.04"
                            android:textColor="@color/claude_text_tertiary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- TODAY section -->
                <TextView
                    android:id="@+id/tvTodaySection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:fontFamily="@font/claude_serif"
                    android:letterSpacing="0.1"
                    android:text="今日课程"
                    android:textAllCaps="true"
                    android:textColor="@color/claude_terracotta"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <!-- Timeline -->
                <LinearLayout
                    android:id="@+id/timelineContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <!-- Empty state (clean text, no lottie) -->
                <LinearLayout
                    android:id="@+id/emptyCoursesState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:orientation="vertical"
                    android:paddingVertical="24dp"
                    android:visibility="gone">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/emptyLottie"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/claude_serif"
                        android:letterSpacing="-0.02"
                        android:text="@string/empty_courses_title"
                        android:textColor="@color/claude_text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/claude_display"
                        android:letterSpacing="0.01"
                        android:text="@string/empty_courses_subtitle"
                        android:textColor="@color/claude_text_tertiary"
                        android:textSize="13sp"
                        android:textStyle="italic" />

                </LinearLayout>

                <!-- Hairline divider before exams -->
                <View
                    android:id="@+id/dividerBeforeExams"
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginTop="32dp"
                    android:background="@color/claude_divider" />

                <!-- EXAMS section -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardExamCountdown"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/claude_bg_subtle"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/claude_serif"
                            android:letterSpacing="0.1"
                            android:text="考试倒计时"
                            android:textAllCaps="true"
                            android:textColor="@color/claude_terracotta"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:id="@+id/examCountdownContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Countdown events (custom user countdowns) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCountdown"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/claude_bg_subtle"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/claude_serif"
                            android:letterSpacing="0.1"
                            android:text="我的倒计时"
                            android:textAllCaps="true"
                            android:textColor="@color/claude_terracotta"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:id="@+id/countdownContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Hot discussion -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHotDiscussion"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/claude_bg_subtle"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/claude_serif"
                                android:letterSpacing="0.1"
                                android:text="校园热议"
                                android:textAllCaps="true"
                                android:textColor="@color/claude_terracotta"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvShowMore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/claude_serif"
                                android:text="查看更多 ›"
                                android:textColor="@color/claude_text_secondary"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/hotDiscussionContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Hairline divider before shortcuts -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginTop="32dp"
                    android:background="@color/claude_divider" />

                <!-- Quick entry heading -->
                <TextView
                    android:id="@+id/tvQuickEntry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/claude_serif"
                    android:letterSpacing="0.1"
                    android:text="快捷入口"
                    android:textAllCaps="true"
                    android:textColor="@color/claude_terracotta"
                    android:textSize="11sp" />

                <!-- Quick entry: text-link list -->
                <LinearLayout
                    android:id="@+id/gridContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/gridSyllabus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/claude_serif"
                            android:text="@string/nav_grid_syllabus"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:alpha="0.4"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/claude_text_tertiary" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:background="@color/claude_divider" />

                    <LinearLayout
                        android:id="@+id/gridElective"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/claude_serif"
                            android:text="@string/nav_elective"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:alpha="0.4"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/claude_text_tertiary" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:background="@color/claude_divider" />

                    <LinearLayout
                        android:id="@+id/gridToolbox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/claude_serif"
                            android:text="KYZZ 工具箱"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:alpha="0.4"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/claude_text_tertiary" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Pet floating widget -->
    <include
        android:id="@+id/petWidget"
        layout="@layout/layout_pet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="24dp" />

</FrameLayout>

