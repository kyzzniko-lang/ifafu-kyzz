<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/claude_bg">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="56dp"
                android:paddingBottom="40dp">

                <!-- Hidden legacy header anchors (kept for code compatibility) -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp">

                    <View
                        android:id="@+id/headerBackground"
                        android:layout_width="0dp"
                        android:layout_height="0dp" />

                    <View
                        android:id="@+id/headerBottomArc"
                        android:layout_width="0dp"
                        android:layout_height="0dp" />
                </FrameLayout>

                <!-- Top row: brand wordmark + settings -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/claude_serif"
                        android:letterSpacing="0.32"
                        android:text="iFAFU"
                        android:textAllCaps="true"
                        android:textColor="@color/claude_text_tertiary"
                        android:textSize="11sp" />

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="设置"
                        android:padding="6dp"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/claude_text_secondary" />

                </LinearLayout>

                <!-- Welcome (typewriter) -->
                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:fontFamily="@font/claude_serif"
                    android:letterSpacing="-0.03"
                    android:lineSpacingMultiplier="1.1"
                    android:textColor="@color/claude_text_primary"
                    android:textSize="42sp"
                    android:textStyle="italic" />

                <!-- Date line -->
                <TextView
                    android:id="@+id/tvDateInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/claude_serif"
                    android:letterSpacing="0.04"
                    android:textColor="@color/claude_text_secondary"
                    android:textSize="14sp" />

                <!-- Quick info chips (text-only, document style) -->
                <HorizontalScrollView
                    android:id="@+id/chipsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:clipToPadding="false"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipWeek"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:background="@drawable/bg_info_chip"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:letterSpacing="0.02"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/claude_terracotta_700"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipCoursesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_info_chip"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:letterSpacing="0.02"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/claude_terracotta_700"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipExamCountdown"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_info_chip"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:letterSpacing="0.02"
                            android:paddingHorizontal="14dp"
                            android:textColor="@color/claude_terracotta_700"
                            android:textSize="12sp" />

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Hairline divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginTop="32dp"
                    android:background="@color/claude_terracotta_200" />

                <!-- Update notification card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardUpdate"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/claude_bg_subtle"
                    app:strokeColor="@color/claude_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/claude_serif"
                                android:letterSpacing="0.08"
                                android:text="发现新版本"
                                android:textAllCaps="true"
                                android:textColor="@color/claude_terracotta"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvUpdateSize"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/claude_serif"
                                android:textColor="@color/claude_text_tertiary"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvUpdateVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/claude_serif"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="17sp" />

                        <TextView
                            android:id="@+id/tvUpdateBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/claude_serif"
                            android:lineSpacingMultiplier="1.45"
                            android:maxLines="2"
                            android:textColor="@color/claude_text_secondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Weather card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWeather"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/claude_serif"
                            android:letterSpacing="0.08"
                            android:text="天气"
                            android:textAllCaps="true"
                            android:textColor="@color/claude_terracotta"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvWeatherSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/claude_serif"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="17sp" />

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/weatherPeriodContainer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />

                        </HorizontalScrollView>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Course progress -->
                <LinearLayout
                    android:id="@+id/courseProgressContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ProgressBar
                            android:id="@+id/courseProgressBar"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="3dp"
                            android:layout_marginEnd="12dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="0"
                            android:progressBackgroundTint="@color/claude_border_light"
                            android:progressTint="@color/claude_text_primary" />

                        <TextView
                            android:id="@+id/courseProgressText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/claude_serif"
                            android:letterSpacing="0.04"
                            android:textColor="@color/claude_text_tertiary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Today courses heading -->
                <TextView
                    android:id="@+id/tvTodaySection"
                    style="@style/ClaudeOverline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:text="今日课程"
                    android:textColor="@color/claude_terracotta"
                    android:visibility="gone" />

                <!-- Timeline -->
                <LinearLayout
                    android:id="@+id/timelineContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/emptyCoursesState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="32dp"
                    android:visibility="gone">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/emptyLottie"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:alpha="0.85"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        android:src="@drawable/bg_empty_state" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/claude_serif"
                        android:letterSpacing="-0.01"
                        android:text="@string/empty_courses_title"
                        android:textColor="@color/claude_text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/claude_serif"
                        android:text="@string/empty_courses_subtitle"
                        android:textColor="@color/claude_text_tertiary"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Exam countdown card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardExamCountdown"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/claude_serif"
                            android:letterSpacing="0.08"
                            android:text="考试倒计时"
                            android:textAllCaps="true"
                            android:textColor="@color/claude_terracotta"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:id="@+id/examCountdownContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Countdown events -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCountdown"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/claude_serif"
                            android:letterSpacing="0.08"
                            android:text="我的倒计时"
                            android:textAllCaps="true"
                            android:textColor="@color/claude_terracotta"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:id="@+id/countdownContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Hot discussion -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHotDiscussion"
                    style="@style/ClaudeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/claude_serif"
                                android:letterSpacing="0.08"
                                android:text="校园热议"
                                android:textAllCaps="true"
                                android:textColor="@color/claude_terracotta"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/claude_serif"
                                android:text="查看更多 ›"
                                android:textColor="@color/claude_text_secondary"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/hotDiscussionContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Quick entry heading -->
                <TextView
                    android:id="@+id/tvQuickEntry"
                    style="@style/ClaudeOverline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:layout_marginBottom="16dp"
                    android:text="快捷入口"
                    android:textColor="@color/claude_terracotta" />

                <LinearLayout
                    android:id="@+id/gridContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/gridSyllabus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_grid_icon">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_grid_syllabus"
                                app:tint="@color/claude_terracotta" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:text="@string/nav_grid_syllabus"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/gridElective"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_grid_icon">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_elective"
                                app:tint="@color/claude_terracotta" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:text="@string/nav_elective"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/gridToolbox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_grid_icon">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_toolbox"
                                app:tint="@color/claude_terracotta" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/claude_serif"
                            android:gravity="center"
                            android:text="KYZZ工具箱"
                            android:textColor="@color/claude_text_primary"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Pet floating widget -->
    <include
        android:id="@+id/petWidget"
        layout="@layout/layout_pet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="24dp" />

</FrameLayout>
