<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/claude_bg"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/ivPetChatAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            android:src="@drawable/pet_cat_idle" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChatPetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/claude_serif"
                android:textColor="@color/claude_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChatPetStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/claude_serif"
                android:textColor="@color/claude_text_hint"
                android:textSize="11sp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseChat"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text="X"
            android:textColor="@color/claude_text_hint"
            android:textSize="14sp"
            app:cornerRadius="18dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/claude_border" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/claude_serif"
        android:text="AI模型切换：GLM回复慢质量高，Qwen回复快质量一般"
        android:textColor="@color/claude_text_hint"
        android:textSize="10sp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="2dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedChip="@+id/chipGlm">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipGlm"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GLM (高质量)"
            android:textSize="11sp"
            android:fontFamily="@font/claude_serif" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipQwen"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qwen (快速)"
            android:textSize="11sp"
            android:fontFamily="@font/claude_serif" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:clipToPadding="false"
        android:padding="16dp"
        android:scrollbars="vertical" />

    <!-- Typing indicator -->
    <TextView
        android:id="@+id/tvTyping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/claude_serif"
        android:text="正在输入..."
        android:textColor="@color/claude_text_hint"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingBottom="12dp"
        android:paddingTop="4dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etChatInput"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:fontFamily="@font/claude_serif"
            android:hint="和宠物说点什么..."
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:textColor="@color/claude_text_primary"
            android:textColorHint="@color/claude_text_hint"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            style="@style/ClaudeButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text=">"
            android:textSize="16sp"
            app:cornerRadius="21dp" />

    </LinearLayout>

</LinearLayout>
